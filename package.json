{
  "name": "oopz-sdk",
  "version": "0.1.0",
  "description": "Node.js SDK for the Oopz voice platform — async-first, event-driven, type-friendly",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "assets/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "oopz",
    "sdk",
    "bot",
    "voice",
    "chat"
  ],
  "license": "MIT",
  "author": "jacksixth",
  "repository": {
    "type": "git",
    "url": "https://github.com/jacksixth/oopz-sdk"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
